[Unit]
Description=Flyscanner button-driven activity scanner
Wants=flyscanner-network.service
After=local-fs.target flyscanner-network.service

[Service]
Type=simple
User=flyscanner
Group=flyscanner
SupplementaryGroups=video gpio
WorkingDirectory=/home/flyscanner/flyscanner
Environment=PYTHONUNBUFFERED=1
Environment=GPIOZERO_PIN_FACTORY=lgpio
EnvironmentFile=-/etc/default/flyscanner
ExecStart=/home/flyscanner/flyscanner/.venv/bin/python /home/flyscanner/flyscanner/flyscannerV2.py $FLYSCANNER_ARGS
Restart=on-failure
RestartSec=5
TimeoutStopSec=10

[Install]
WantedBy=multi-user.target
